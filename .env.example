# Database Configuration
POSTGRES_USER=blitzball
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=blitzball
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy / Backend URL
# For local dev outside docker: postgresql+psycopg://blitzball:password@localhost:5432/blitzball
# For docker-compose: postgresql+psycopg://blitzball:password@postgres:5432/blitzball
DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Environment
APP_ENV=dev

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
